<div class="nwo-app">
  <header class="nwo-app-header">
    <h2>{{localize "NWO.Apps.Placeholder.Title"}}</h2>
  </header>

  <section class="nwo-app-body">
    <p>{{localize "NWO.Apps.Placeholder.Description"}}</p>
  </section>

  <footer class="nwo-app-footer">
    <button type="button" class="nwo-app-close" data-action="close">
      {{localize "NWO.Close"}}
    </button>
  </footer>
</div>